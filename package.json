{
    "name": "dotpi",
    "version": "1.0.0",
    "description": "Personal pi coding agent setup — extensions, skills, themes, and prompts",
    "keywords": [
        "pi-package"
    ],
    "type": "module",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest"
    },
    "license": "MIT",
    "author": "Simone Peniti",
    "pi": {
        "extensions": [
            "./extensions"
        ],
        "themes": [
            "./themes"
        ],
        "skills": [
            "./skills"
        ],
        "prompts": [
            "./prompts"
        ]
    },
    "peerDependencies": {
        "@mariozechner/pi-ai": "^0.68",
        "@mariozechner/pi-coding-agent": "^0.68",
        "@mariozechner/pi-tui": "^0.68",
        "@sinclair/typebox": "^0.34"
    },
    "devDependencies": {
        "@eslint/js": "^10",
        "@vitest/coverage-v8": "^4",
        "eslint": "^10",
        "eslint-config-prettier": "^10",
        "prettier": "^3",
        "typescript-eslint": "^8",
        "vitest": "^4"
    }
}
