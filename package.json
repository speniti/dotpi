{
    "name": "dotpi",
    "version": "1.0.0",
    "description": "Personal pi coding agent setup — extensions, skills, themes, and prompts",
    "keywords": [
        "pi-package"
    ],
    "type": "module",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest"
    },
    "license": "MIT",
    "author": "Simone Peniti",
    "pi": {
        "extensions": [
            "./extensions"
        ],
        "themes": [
            "./themes"
        ],
        "skills": [
            "./skills"
        ],
        "prompts": [
            "./prompts"
        ]
    },
    "peerDependencies": {
        "@earendil-works/pi-ai": "^0",
        "@earendil-works/pi-coding-agent": "^0",
        "@earendil-works/pi-tui": "^0",
        "@sinclair/typebox": "^0"
    },
    "devDependencies": {
        "@eslint/js": "^10",
        "@vitest/coverage-v8": "^4",
        "eslint": "^10",
        "eslint-config-prettier": "^10",
        "prettier": "^3",
        "typescript-eslint": "^8",
        "vitest": "^4"
    },
    "dependencies": {
        "tree-sitter-bash": "0.25.1",
        "web-tree-sitter": "0.26.8"
    }
}
